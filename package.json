{
  "name": "apx-fs-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "kill:dev-port": "lsof -ti:3003 | xargs kill -9 2>/dev/null || true",
    "predev": "npm run kill:dev-port",
    "dev:clean": "npm run kill:dev-port && next dev -p 3003",
    "dev": "next dev -p 3003",
    "dev:turbo": "next dev --turbopack -p 3003",
    "dev:stable": "npm run kill:dev-port && next dev -p 3003",
    "build": "next build",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@types/styled-components": "^5.1.34",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
